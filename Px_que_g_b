  WHERE  ash.sql_id = '&&sql_id'
    AND  ash.dbid = (SELECT dbid FROM v$database)
    AND  ash.sample_time BETWEEN TO_DATE(REPLACE('&&start_ts','_',' '), 'YYYY-MM-DD HH24:MI')
                             AND TO_DATE(REPLACE('&&end_ts','_',' '),   'YYYY-MM-DD HH24:MI')
),
skew AS (
  SELECT MAX(skew_ratio) AS top_skew_ratio
  FROM (
    SELECT ROUND(MAX(slave_samples) / NULLIF(MIN(slave_samples), 0), 1) AS skew_ratio
    FROM (
      SELECT ash.qc_session_id,
             ash.qc_instance_id,
             ash.session_id,
             COUNT(*) AS slave_samples
      FROM   dba_hist_active_sess_history ash
      WHERE  ash.sql_id = '&&sql_id'
        AND  ash.dbid = (SELECT dbid FROM v$database)
        AND  ash.qc_session_id IS NOT NULL
        AND  ash.sample_time BETWEEN TO_DATE(REPLACE('&&start_ts','_',' '), 'YYYY-MM-DD HH24:MI')
                                 AND TO_DATE(REPLACE('&&end_ts','_',' '),   'YYYY-MM-DD HH24:MI')
      GROUP  BY ash.qc_session_id, ash.qc_instance_id, ash.session_id
    )
    GROUP  BY qc_session_id, qc_instance_id
  )
)
SELECT '&&sql_id' AS sql_id,
       '&&label'  AS label,
       NVL(execs.execs, 0) AS execs,
       NVL(execs.avg_elapsed_s, 0) AS avg_elapsed_s,
       NVL(execs.avg_cpu_s, 0) AS avg_cpu_s,
       NVL(execs.avg_iowait_s, 0) AS avg_iowait_s,
       NVL(ash_evt.on_cpu_pct, 0) AS on_cpu_pct,
       NVL(ash_evt.temp_pct, 0) AS temp_pct,
       NVL(skew.top_skew_ratio, 0) AS top_skew_ratio
FROM   execs, ash_evt, skew;
