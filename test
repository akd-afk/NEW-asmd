      AND  ash.qc_session_id = TO_NUMBER('&&v_qc_sid')
      AND  ash.qc_instance_id = TO_NUMBER('&&v_qc_inst')
      AND  ash.sample_time BETWEEN TO_DATE(REPLACE('&&p_start_ts','_',' '), 'YYYY-MM-DD HH24:MI')
                               AND TO_DATE(REPLACE('&&p_end_ts','_',' '),   'YYYY-MM-DD HH24:MI')
    GROUP  BY ash.session_id
  )
),
mon AS (
  SELECT MAX(ROUND(m.elapsed_time/1e6,2)) AS elapsed_s,
         MAX(ROUND(m.cpu_time/1e6,2)) AS cpu_s,
         MAX(ROUND(m.user_io_wait_time/1e6,2)) AS io_wait_s,
         MAX(m.px_servers_requested) AS px_req,
         MAX(m.px_servers_allocated) AS px_alloc,
         MAX(m.sql_plan_hash_value) AS plan_hash
  FROM   gv$sql_monitor m
  WHERE  m.sql_id = '&&p_sql_id'
    AND  m.sql_exec_start BETWEEN TO_DATE(REPLACE('&&p_start_ts','_',' '), 'YYYY-MM-DD HH24:MI')
                              AND TO_DATE(REPLACE('&&p_end_ts','_',' '),   'YYYY-MM-DD HH24:MI')
)
SELECT '&&p_sql_id' AS sql_id,
       '&&p_label' AS label,
       '&&v_qc_sid' AS qc_sid,
       '&&v_qc_inst' AS qc_inst,
       mon.elapsed_s,
       mon.cpu_s,
       mon.io_wait_s,
       mon.px_req,
       mon.px_alloc,
       mon.plan_hash,
       evt.on_cpu_pct,
       evt.temp_pct,
       sk.skew_ratio
FROM   evt, sk, mon;

UNDEFINE p_sql_id
UNDEFINE p_label
UNDEFINE p_start_ts
UNDEFINE p_end_ts
UNDEFINE p_qc_sid
UNDEFINE p_qc_inst
UNDEFINE v_qc_sid
UNDEFINE v_qc_inst
