-- ============================================================================
-- File: ash_event_lookup_templates.sql
-- Purpose:
--   Query ASH for a given SQL_ID and event, with safe runtime prompts only.
--   Includes:
--     1) Current-memory ASH for "today"
--     2) Current-memory ASH for a custom time window
--     3) DBA_HIST ASH for a custom time window
--     4) Optional summary query by instance/module/action
--
-- Notes:
--   - No sensitive values are hardcoded.
--   - Uses SQL*Plus / SQLcl ACCEPT prompts.
--   - DBA_HIST_ACTIVE_SESS_HISTORY requires proper Diagnostic Pack licensing.
--   - EVENT should usually be entered exactly as seen, for example:
--       resmgr:cpu quantum
-- ============================================================================

set pages 500
set lines 320
set trimspool on
set verify off
set feedback on
set echo off
set tab off

prompt =========================================================================
prompt ASH EVENT LOOKUP TEMPLATES
prompt =========================================================================
prompt Available sections in this file:
prompt   1. Today only from GV$ACTIVE_SESSION_HISTORY
prompt   2. Custom time window from GV$ACTIVE_SESSION_HISTORY
prompt   3. Custom time window from DBA_HIST_ACTIVE_SESS_HISTORY
prompt   4. Summary by instance / module / action
prompt =========================================================================

-- Common display formatting
col sample_time                  format a20
col inst_id                      format 999999
col module                       format a24
col session_id                   format 999999
col session_serial#              format 999999
col sql_id                       format a15
col event                        format a30
col action                       format a35
col blocking_session             format 999999
col blocking_session_serial#     format 999999
col current_obj#                 format 999999999999
col samples                      format 999999999
col first_seen                   format a20
col last_seen                    format a20

-- ============================================================================
-- 1) TODAY ONLY FROM GV$ACTIVE_SESSION_HISTORY
-- ============================================================================
prompt
prompt [SECTION 1] Today-only ASH query from GV$ACTIVE_SESSION_HISTORY
prompt

accept p1_sql_id char prompt 'Enter SQL_ID: '
accept p1_event  char prompt 'Enter EVENT text exactly: '

select
    to_char(sample_time,'DD-MON-YYYY HH24:MI:SS') as sample_time,
    inst_id,
    module,
    session_id,
    session_serial#,
    sql_id,
    event,
    action,
    blocking_session,
    blocking_session_serial#,
    current_obj#
from gv$active_session_history
where sample_time >= trunc(sysdate)
  and sample_time <  trunc(sysdate) + 1
  and sql_id = trim('&p1_sql_id')
  and event  = trim('&p1_event')
order by sample_time desc, inst_id, session_id;

undefine p1_sql_id
undefine p1_event

-- ============================================================================
-- 2) CUSTOM TIME WINDOW FROM GV$ACTIVE_SESSION_HISTORY
-- ============================================================================
prompt
prompt [SECTION 2] Time-window ASH query from GV$ACTIVE_SESSION_HISTORY
prompt Timestamp format required: DD-MON-YYYY HH24:MI:SS
prompt

accept p2_sql_id   char prompt 'Enter SQL_ID: '
accept p2_event    char prompt 'Enter EVENT text exactly: '
accept p2_from_ts  char prompt 'Enter start time (DD-MON-YYYY HH24:MI:SS): '
accept p2_to_ts    char prompt 'Enter end time   (DD-MON-YYYY HH24:MI:SS): '

select
    to_char(sample_time,'DD-MON-YYYY HH24:MI:SS') as sample_time,
    inst_id,
    module,
    session_id,
    session_serial#,
    sql_id,
    event,
    action,
    blocking_session,
    blocking_session_serial#,
    current_obj#
from gv$active_session_history
where sample_time >= to_date('&p2_from_ts','DD-MON-YYYY HH24:MI:SS')
  and sample_time <= to_date('&p2_to_ts'  ,'DD-MON-YYYY HH24:MI:SS')
  and sql_id = trim('&p2_sql_id')
  and event  = trim('&p2_event')
order by sample_time desc, inst_id, session_id;

undefine p2_sql_id
undefine p2_event
undefine p2_from_ts
undefine p2_to_ts

-- ============================================================================
-- 3) CUSTOM TIME WINDOW FROM DBA_HIST_ACTIVE_SESS_HISTORY
-- ============================================================================
prompt
prompt [SECTION 3] Time-window query from DBA_HIST_ACTIVE_SESS_HISTORY
prompt Timestamp format required: DD-MON-YYYY HH24:MI:SS
prompt Requires Diagnostic Pack licensing compliance
prompt

accept p3_sql_id   char prompt 'Enter SQL_ID: '
accept p3_event    char prompt 'Enter EVENT text exactly: '
accept p3_from_ts  char prompt 'Enter start time (DD-MON-YYYY HH24:MI:SS): '
accept p3_to_ts    char prompt 'Enter end time   (DD-MON-YYYY HH24:MI:SS): '

select
    to_char(sample_time,'DD-MON-YYYY HH24:MI:SS') as sample_time,
    instance_number as inst_id,
    module,
    session_id,
    session_serial#,
    sql_id,
    event,
    action,
    blocking_session,
    blocking_session_serial#,
    current_obj#
from dba_hist_active_sess_history
where sample_time >= to_date('&p3_from_ts','DD-MON-YYYY HH24:MI:SS')
  and sample_time <= to_date('&p3_to_ts'  ,'DD-MON-YYYY HH24:MI:SS')
  and sql_id = trim('&p3_sql_id')
  and event  = trim('&p3_event')
order by sample_time desc, inst_id, session_id;

undefine p3_sql_id
undefine p3_event
undefine p3_from_ts
undefine p3_to_ts

-- ============================================================================
-- 4) OPTIONAL SUMMARY BY INSTANCE / MODULE / ACTION
-- ============================================================================
prompt
prompt [SECTION 4] Summary counts from GV$ACTIVE_SESSION_HISTORY
prompt Timestamp format required: DD-MON-YYYY HH24:MI:SS
prompt

accept p4_sql_id   char prompt 'Enter SQL_ID: '
accept p4_event    char prompt 'Enter EVENT text exactly: '
accept p4_from_ts  char prompt 'Enter start time (DD-MON-YYYY HH24:MI:SS): '
accept p4_to_ts    char prompt 'Enter end time   (DD-MON-YYYY HH24:MI:SS): '

select
    inst_id,
    nvl(module,'<null>') as module,
    nvl(action,'<null>') as action,
    count(*) as samples,
    to_char(min(sample_time),'DD-MON-YYYY HH24:MI:SS') as first_seen,
    to_char(max(sample_time),'DD-MON-YYYY HH24:MI:SS') as last_seen
from gv$active_session_history
where sample_time >= to_date('&p4_from_ts','DD-MON-YYYY HH24:MI:SS')
  and sample_time <= to_date('&p4_to_ts'  ,'DD-MON-YYYY HH24:MI:SS')
  and sql_id = trim('&p4_sql_id')
  and event  = trim('&p4_event')
group by inst_id, module, action
order by samples desc, inst_id, module, action;

undefine p4_sql_id
undefine p4_event
undefine p4_from_ts
undefine p4_to_ts

prompt
prompt =========================================================================
prompt TIMESTAMP EXAMPLES
prompt =========================================================================
prompt 25-MAR-2026 00:00:00
prompt 25-MAR-2026 02:00:00
prompt 25-MAR-2026 02:01:34
prompt 25-MAR-2026 02:04:14
prompt 25-MAR-2026 03:06:57
prompt =========================================================================

prompt
prompt =========================================================================
prompt EXECUTION EXAMPLES
prompt =========================================================================
prompt Example 1 - run the script:
prompt   @ash_event_lookup_templates.sql
prompt
prompt Example 2 - values to enter when prompted:
prompt   SQL_ID  : your_sql_id_here
prompt   EVENT   : resmgr:cpu quantum
prompt   FROM_TS : 25-MAR-2026 02:00:00
prompt   TO_TS   : 25-MAR-2026 03:10:00
prompt
prompt Example 3 - spool output first:
prompt   spool ash_event_output_25mar2026.lst
prompt   @ash_event_lookup_templates.sql
prompt   spool off
prompt =========================================================================

