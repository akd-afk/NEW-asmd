#!/usr/bin/env bash
set -euo pipefail

# Exadata cell-side RCA collector
# Collects current cell metrics and optional history in one shot.
# Designed for readability under time pressure.
#
# Requirements:
#   - dcli installed on the caller host
#   - passwordless connectivity to storage cells
#   - group file listing storage cells
#
# Notes:
#   - Current metric sections are reliable for active incidents.
#   - History collection is best-effort because metric names / filters can vary by image release.
#   - This script is read-only. It does not modify cells.

GROUP_FILE="/root/cell_group"
REMOTE_USER="root"
OUTDIR="./cell_rca_$(date +%Y%m%d_%H%M%S)"
START_TS=""
END_TS=""
KEEP_RAW=0

usage() {
  cat <<'USAGE'
Usage: exadata_cell_rca.sh [-g group_file] [-u remote_user] [-o outdir] [-s start_ts] [-e end_ts] [-k]

  -g  dcli group file for storage cells (default: /root/cell_group)
  -u  remote user (default: root)
  -o  output directory (default: ./cell_rca_<timestamp>)
  -s  optional start timestamp for history extraction, format: YYYY-MM-DD HH:MI:SS
  -e  optional end timestamp for history extraction, format: YYYY-MM-DD HH:MI:SS
  -k  keep raw dcli output files (raw files are kept by default regardless; this flag is informational)
  -h  show help

Examples:
  ./exadata_cell_rca.sh
  ./exadata_cell_rca.sh -g /root/cell_group -o /tmp/cell_rca_now
  ./exadata_cell_rca.sh -s '2026-03-21 05:00:00' -e '2026-03-21 09:30:00'
USAGE
}

while getopts ":g:u:o:s:e:kh" opt; do
  case "$opt" in
    g) GROUP_FILE="$OPTARG" ;;
    u) REMOTE_USER="$OPTARG" ;;
    o) OUTDIR="$OPTARG" ;;
    s) START_TS="$OPTARG" ;;
    e) END_TS="$OPTARG" ;;
    k) KEEP_RAW=1 ;;
    h) usage; exit 0 ;;
    :) echo "Option -$OPTARG requires an argument" >&2; usage; exit 1 ;;
    \?) echo "Invalid option: -$OPTARG" >&2; usage; exit 1 ;;
  esac
done

if [[ ! -f "$GROUP_FILE" ]]; then
  echo "Group file not found: $GROUP_FILE" >&2
  exit 1
fi

if [[ -n "$START_TS" && -z "$END_TS" ]] || [[ -z "$START_TS" && -n "$END_TS" ]]; then
  echo "Provide both -s and -e, or neither." >&2
  exit 1
fi

mkdir -p "$OUTDIR"
SUMMARY_FILE="$OUTDIR/00_summary.txt"
RAW_DIR="$OUTDIR/raw"
mkdir -p "$RAW_DIR"

START_GREP=""
END_GREP=""
if [[ -n "$START_TS" ]]; then
  START_GREP="${START_TS/ /T}"
  END_GREP="${END_TS/ /T}"
fi

section() {
  local title="$1"
  {
    echo
    echo "===================================================================="
    echo "$title"
    echo "===================================================================="
  } | tee -a "$SUMMARY_FILE"
}

run_dcli() {
  local label="$1"
  local cmd="$2"
  local outfile="$RAW_DIR/${label}.txt"

  echo "[RUNNING] $label" | tee -a "$SUMMARY_FILE"
  if dcli -g "$GROUP_FILE" -l "$REMOTE_USER" "$cmd" > "$outfile" 2>&1; then
    :
  else
    echo "[WARN] dcli section failed: $label" | tee -a "$SUMMARY_FILE"
  fi
}

append_top_lines() {
  local label="$1"
  local lines="${2:-200}"
  local file="$RAW_DIR/${label}.txt"
  if [[ -f "$file" ]]; then
    {
      echo "--- $label ---"
      sed -n "1,${lines}p" "$file"
    } >> "$SUMMARY_FILE"
  fi
}

section "INPUTS"
{
  echo "Group file : $GROUP_FILE"
  echo "Remote user: $REMOTE_USER"
  echo "Output dir : $OUTDIR"
  if [[ -n "$START_TS" ]]; then
    echo "History from: $START_TS"
    echo "History to  : $END_TS"
  else
    echo "History     : not requested"
  fi
  echo
  echo "Read this summary in this order:"
  echo "  1) CURRENT DISK LATENCY"
  echo "  2) CURRENT UTILIZATION"
  echo "  3) CURRENT CELLSRV METRICS"
  echo "  4) ALERT LOG CLUES"
} | tee -a "$SUMMARY_FILE"

# 1) Environment / version / cell state
run_dcli "01_env" "bash -lc 'echo HOST=\$(hostname -s); date; uptime; echo; imageinfo 2>/dev/null | head -40; echo; cellcli -e \"list cell detail\" 2>/dev/null | egrep -i \"name:|status:|cellVersion:|releaseImageVersion:|cpuCount:|ramCacheMaxSize:|flashCacheMode:|flashCacheCompress:|offloadGroupName:|diagHistoryDays:\"'"
section "CELL ENVIRONMENT / VERSION / BASIC STATE"
append_top_lines "01_env" 300

# 2) Alert log clues
run_dcli "02_alertlog" "bash -lc 'echo HOST=\$(hostname -s); echo; egrep -i \"rebalance|grid disk|griddisk|celldisk|flashdisk|resize|drop|create|online|offline|warning|error|critical|asm\" /var/log/cellos/alert.log 2>/dev/null | tail -200'"
section "ALERT LOG CLUES (rebalance / disk / warnings / errors)"
append_top_lines "02_alertlog" 260

# 3) Current cellsrv metrics: IOPS / BYTES / offload / flash cache
run_dcli "03_cellsrv_current" "bash -lc 'echo HOST=\$(hostname -s); echo; cellcli -e \"list metriccurrent where metricObjectName = \'CELLSRV\' attributes metricObjectName,name,metricValue\" 2>/dev/null | egrep -i \"IO_RQ_|IO_BY_|FC_|SAVED|OPTIMIZED|OFFLOAD\"'"
section "CURRENT CELLSRV METRICS (IOPS / MBPS / offload / flash cache)"
append_top_lines "03_cellsrv_current" 300

# 4) Current celldisk + flashdisk latency
run_dcli "04_latency_current" "bash -lc 'echo HOST=\$(hostname -s); echo; cellcli -e \"list metriccurrent attributes metricObjectName,name,metricValue\" 2>/dev/null | egrep -i \"(CELLDISK|FLASHDISK).*(CD_IO_.*_LAT|FD_IO_.*_LAT)|(^[[:space:]]*(CELLDISK|FLASHDISK))\"'"
section "CURRENT DISK LATENCY (CELLDISK / FLASHDISK)"
append_top_lines "04_latency_current" 350

# 5) Current utilization
run_dcli "05_util_current" "bash -lc 'echo HOST=\$(hostname -s); echo; cellcli -e \"list metriccurrent attributes metricObjectName,name,metricValue\" 2>/dev/null | egrep -i \"(CELLDISK|GRIDDISK).*(CD_UTIL|GD_UTIL)|(^[[:space:]]*(CELLDISK|GRIDDISK))\"'"
section "CURRENT UTILIZATION (CELLDISK / GRIDDISK)"
append_top_lines "05_util_current" 350

# 6) OS perspective on the cell
run_dcli "06_os_iostat" "bash -lc 'echo HOST=\$(hostname -s); echo; iostat -xmd 1 3 2>/dev/null; echo; vmstat 1 5 2>/dev/null'"
section "OS VIEW (iostat / vmstat)"
append_top_lines "06_os_iostat" 300

# 7) Optional history sections
if [[ -n "$START_TS" ]]; then
  run_dcli "07_hist_cellsrv" "bash -lc 'echo HOST=\$(hostname -s); echo; cellcli -e \"list metrichistory where metricObjectName = \'CELLSRV\' attributes metricObjectName,name,collectionTime,metricValue\" 2>/dev/null | egrep -i \"IO_RQ_|IO_BY_|FC_|SAVED|OPTIMIZED|OFFLOAD\" | egrep \"${START_GREP:0:13}|${END_GREP:0:13}|${START_GREP:0:10}|${END_GREP:0:10}\"'"
  section "HISTORICAL CELLSRV METRICS (best-effort filtered)"
  append_top_lines "07_hist_cellsrv" 400

  run_dcli "08_hist_latency" "bash -lc 'echo HOST=\$(hostname -s); echo; cellcli -e \"list metrichistory attributes metricObjectName,name,collectionTime,metricValue\" 2>/dev/null | egrep -i \"(CELLDISK|FLASHDISK).*(CD_IO_.*_LAT|FD_IO_.*_LAT)\" | egrep \"${START_GREP:0:13}|${END_GREP:0:13}|${START_GREP:0:10}|${END_GREP:0:10}\"'"
  section "HISTORICAL LATENCY METRICS (best-effort filtered)"
  append_top_lines "08_hist_latency" 400

  run_dcli "09_hist_util" "bash -lc 'echo HOST=\$(hostname -s); echo; cellcli -e \"list metrichistory attributes metricObjectName,name,collectionTime,metricValue\" 2>/dev/null | egrep -i \"(CELLDISK|GRIDDISK).*(CD_UTIL|GD_UTIL)\" | egrep \"${START_GREP:0:13}|${END_GREP:0:13}|${START_GREP:0:10}|${END_GREP:0:10}\"'"
  section "HISTORICAL UTILIZATION METRICS (best-effort filtered)"
  append_top_lines "09_hist_util" 400
fi

section "QUICK INTERPRETATION GUIDE"
{
  cat <<'GUIDE'
1) If H20 / CELLDISK latency and utilization are both elevated, that supports real storage-side pressure.
2) If small-read IOPS are very high but latency remains low, that usually means workload shape changed, not that storage is failing.
3) If FI / FLASHDISK latency is healthy, flash is probably not the bottleneck.
4) If direct-path-temp waits are high on the database side AND H20 latency/utilization are elevated, storage may be amplifying spill-heavy SQL.
5) If alert.log shows rebalance / grid disk create/drop/resize overlapping the incident, include that as a contributing factor in the RCA.
6) Compare good and bad windows side by side. Do not conclude a storage bottleneck from IOPS alone; always check latency and utilization.
GUIDE
} | tee -a "$SUMMARY_FILE"

section "OUTPUT"
{
  echo "Summary report : $SUMMARY_FILE"
  echo "Raw outputs    : $RAW_DIR"
  if [[ -n "$START_TS" ]]; then
    echo "History window : $START_TS to $END_TS"
  fi
} | tee -a "$SUMMARY_FILE"

printf '\nDone. Review: %s\n' "$SUMMARY_FILE"
